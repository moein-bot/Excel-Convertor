# Mapping Configuration

Stored separately:

```
mapping.json
```

Example:

```json
{
  "source_sheet": "Users",
  "destination_sheet": "Sheet1",

  "fields": [

    {
      "source": "نام",
      "target": "Name",
      "type": "string",
      "transform": [
        "trim"
      ]
    },

    {
      "source": "نام خانوادگی",
      "target": "LName",
      "type": "string",
      "transform": [
        "trim"
      ]
    },

    {
      "source": "شماره شناسنامه",
      "target": "IdentityNo",
      "type": "string"
    },


    {
      "source": "تاریخ تولد",
      "target": [
        "BirthYear",
        "BirthMonth",
        "BirthDay"
      ],
      "type": "persian_date"
    },


    {
      "source": "کد ملی",
      "target": "CodeMelli",
      "type": "string"
    },


    {
      "source": "جنسیت",
      "target": "Jens",
      "type": "mapping",

      "values": {
        "1": 26,
        "2": 27
      }
    },


    {
      "source": "کد وضعیت تأهل",
      "target": "tahol",
      "type": "mapping",

      "values": {
        "2": 76,
        "3": 77
      }
    }

  ]
}
```

